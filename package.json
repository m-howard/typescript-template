{
    "name": "project-name",
    "version": "1.0.0",
    "description": "A TypeScript starter template.",
    "author": "github.com/m-howard",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "tsc",
        "clean": "./scripts/clean.sh",
        "dev": "echo \"Not yet implemented\"",
        "format": "prettier --write \"./**/*.{ts,mjs,json,md}\"",
        "format:check": "prettier --check \"./**/*.{ts,mjs,json,md}\"",
        "lint": "eslint \"{src,test,scripts}/**/*.{ts,js}\" --fix",
        "lint:check": "eslint \"{src,test,scripts}/**/*.{ts,js}\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "prepare": "husky"
    },
    "dependencies": {
        "@types/morgan": "^1.9.10",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "lodash": "^4.17.21",
        "morgan": "^1.10.0",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "@clerk/clerk-sdk-node": "^4.13.23",
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@faker-js/faker": "^9.6.0",
        "@swc/cli": "^0.6.0",
        "@swc/core": "^1.10.7",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/lodash": "^4.17.18",
        "@types/node": "^22.10.7",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^10.0.0",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^16.0.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "nano-staged": "^0.8.0",
        "prettier": "^3.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.1.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0",
        "uuid": "^11.1.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "src/**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node"
    },
    "nano-staged": {
        "*.{md,mjs,ts,json}": [
            "npm run format"
        ],
        "*.{mjs,ts}": [
            "npm run lint"
        ]
    }
}
